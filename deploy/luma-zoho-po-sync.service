[Unit]
Description=Luma daily Zoho purchase-order sync
Wants=network-online.target docker.service
After=network-online.target docker.service

[Service]
Type=oneshot
ExecStart=/bin/bash -c 'set -a; source /etc/luma/zoho-cron.env; set +a; curl -sf -X POST -H "Authorization: Bearer ${LUMA_CRON_SECRET}" -H "Content-Type: application/json" http://127.0.0.1:3000/api/cron/zoho-po-sync'

[Install]
WantedBy=multi-user.target
