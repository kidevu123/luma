# Required
AUTH_SECRET=change-me-32+-bytes
POSTGRES_PASSWORD=change-me

# App
APP_URL=http://localhost:3000
APP_PORT=3000

# Telemetry — Prometheus scrape exposed on this port
OTEL_PROM_HOST_PORT=9464
# Optional OTLP traces target
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_SERVICE_NAME=luma
OTEL_DEPLOYMENT_ENVIRONMENT=production

# Zoho — call the centralized integration service on the Proxmox network.
# The service runs on LXC 9503 (zoho-integration-service) at 192.168.1.205:8000.
# Shared-secret auth: gateway expects X-Internal-Token; Luma sends it as
# x-luma-zoho-secret (header name set by lib/integrations/zoho/gateway.ts).
ZOHO_INTEGRATION_URL=http://192.168.1.205:8000
ZOHO_INTEGRATION_SECRET=
# Multi-brand gateway: which brand's Zoho creds to use. Sent on every
# protected gateway call as X-Brand. Required for ZOHO-2 onward.
# Haute Nutrition production data lives under haute_brands.
ZOHO_BRAND=haute_brands

# Zoho Integration Service v1.10.0 — assembly write endpoints
# Bearer secret for /zoho/purchase_receives/create and /zoho/assemblies/create.
# Issued by the Zoho Integration Service operator; distinct from ZOHO_INTEGRATION_SECRET.
ZOHO_SERVICE_BEARER_SECRET=
# Zoho warehouse ID for haute_brands — included in purchase receive and assembly payloads when set.
# Leave blank if not yet confirmed with the Zoho Integration Service operator.
ZOHO_WAREHOUSE_ID=
# Feature flag: set to "true" to enable dry-run requests to Zoho Integration Service.
# Leave unset (or "false") to block all assembly dry-run network calls.
ZOHO_DRY_RUN_WRITES_ENABLED=false

# Authentik OIDC (optional — fall back to local email+password if blank)
AUTHENTIK_ISSUER=
AUTHENTIK_CLIENT_ID=
AUTHENTIK_CLIENT_SECRET=
